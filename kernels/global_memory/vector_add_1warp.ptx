// Purpose: Compute C[i] = A[i] + B[i] for one warp.
// Primary feature: global_memory
// Expected outcome: success
.version 8.0
.target spinalgpu
.address_size 32

.visible .entry vector_add_1warp(
    .param .u32 a_ptr_param,
    .param .u32 b_ptr_param,
    .param .u32 c_ptr_param
)
{
    .reg .u32 %r<10>;

    // Setup
    ld.param.u32 %r0, [a_ptr_param];
    ld.param.u32 %r1, [b_ptr_param];
    ld.param.u32 %r2, [c_ptr_param];
    mov.u32 %r3, %tid.x;

    // Core
    shl.b32 %r4, %r3, 2;
    add.u32 %r5, %r0, %r4;
    add.u32 %r6, %r1, %r4;
    add.u32 %r7, %r2, %r4;
    ld.global.u32 %r8, [%r5];
    ld.global.u32 %r9, [%r6];
    add.u32 %r8, %r8, %r9;
    st.global.u32 [%r7], %r8;

    // Exit
    ret;
}
