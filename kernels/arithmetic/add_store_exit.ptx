// Purpose: Write a constant arithmetic result to global memory.
// Primary feature: arithmetic
// Expected outcome: success
.version 8.0
.target spinalgpu
.address_size 32

.visible .entry add_store_exit(
    .param .u32 out_ptr_param
)
{
    .reg .u32 %r<4>;

    // Setup
    ld.param.u32 %r0, [out_ptr_param];

    // Core
    mov.u32 %r1, 7;
    mov.u32 %r2, 11;
    add.u32 %r3, %r1, %r2;
    st.global.u32 [%r0], %r3;

    // Exit
    ret;
}
