// Purpose: Convert one packed E5M2x2 value per thread into one packed F16x2 value.
// Primary feature: floating_point
// Expected outcome: success
// High-level execution flow:
// - Each thread loads one 16-bit carrier containing two E5M2 values.
// - The kernel converts the packed input into one packed `f16x2` result.
// - The packed half2 value is stored back to global memory.
// Where this fits:
// - This mirrors the E4M3 conversion case for the second official-like FP8 format.
// - It proves that both packed alternate formats are wired into the CUDA-core path.
// Key model details:
// - Input carriers use 2-byte spacing; output `f16x2` values use 4-byte spacing.
// - There is no arithmetic in this kernel, only packed format conversion.
// - The packed result still occupies one 32-bit physical register slot.
// CUDA-equivalent sketch (.cu):
// __global__ void scalar_convert_e5m2x2_f16x2(const uint16_t* in_bits, uint32_t* out_half2_bits) {
//   unsigned i = threadIdx.x;
//   out_half2_bits[i] = convert_e5m2x2_to_half2(in_bits[i]);
// }
// SpinalGPU note:
// - This stays on the CUDA-core datapath; tensor instructions are still out of scope.

.version 8.0
.target spinalgpu
.address_size 32

.visible .entry scalar_convert_e5m2x2_f16x2(
    .param .u32 in_ptr,
    .param .u32 out_ptr
)
{
    .reg .u32 %r<6>;
    .reg .b16 %b<1>;
    .reg .f16x2 %x<1>;

// Setup
    ld.param.u32 %r0, [in_ptr];
    ld.param.u32 %r1, [out_ptr];
    mov.u32 %r2, %tid.x;
    shl.b32 %r3, %r2, 1;
    shl.b32 %r4, %r2, 2;
    add.u32 %r3, %r0, %r3;
    add.u32 %r4, %r1, %r4;

// Core
    ld.global.b16 %b0, [%r3];
    cvt.rn.f16x2.e5m2x2 %x0, %b0;
    st.global.f16x2 [%r4], %x0;

// Exit
    ret;
}
