// Purpose: Convert one packed E4M3x2 value per thread into one packed F16x2 value.
// Primary feature: floating_point
// Expected outcome: success
// High-level execution flow:
// - Each thread loads one packed 16-bit FP8 carrier from global memory.
// - The kernel converts the two embedded E4M3 values into one packed `f16x2` register.
// - The converted packed half values are written back to global memory.
// Where this fits:
// - This is the smallest end-to-end proof that the official-like packed FP8 conversion path exists.
// - It focuses on `cvt.rn.f16x2.e4m3x2` without mixing in arithmetic.
// Key model details:
// - Input carriers are 16-bit packed words stored every 2 bytes.
// - Output `f16x2` tuples occupy 4 bytes each.
// - Each carrier stores two logical low-precision values in one thread-local packed register.
// CUDA-equivalent sketch (.cu):
// __global__ void scalar_convert_e4m3x2_f16x2(const uint16_t* in_bits, uint32_t* out_half2_bits) {
//   unsigned i = threadIdx.x;
//   // Approximate CUDA-side sketch: one packed FP8x2 word converts into one packed half2 word.
//   out_half2_bits[i] = convert_e4m3x2_to_half2(in_bits[i]);
// }
// SpinalGPU note:
// - This uses the repo’s teaching PTX surface for packed FP8 alternate formats; normal CUDA source would spell this through intrinsics or inline PTX.

.version 8.0
.target spinalgpu
.address_size 32

.visible .entry scalar_convert_e4m3x2_f16x2(
    .param .u32 in_ptr,
    .param .u32 out_ptr
)
{
    .reg .u32 %r<6>;
    .reg .b16 %b<1>;
    .reg .f16x2 %x<1>;

// Setup
    ld.param.u32 %r0, [in_ptr];
    ld.param.u32 %r1, [out_ptr];
    mov.u32 %r2, %tid.x;          // Packed-element index.
    shl.b32 %r3, %r2, 1;          // FP8x2 carrier byte offset.
    shl.b32 %r4, %r2, 2;          // F16x2 tuple byte offset.
    add.u32 %r3, %r0, %r3;
    add.u32 %r4, %r1, %r4;

// Core
    ld.global.b16 %b0, [%r3];
    cvt.rn.f16x2.e4m3x2 %x0, %b0;
    st.global.f16x2 [%r4], %x0;

// Exit
    ret;
}
