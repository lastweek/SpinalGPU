// Purpose: Store the basic lane, warp, block, and SM special-register values to global memory.
// Primary feature: special_registers
// Expected outcome: success
.version 8.0
.target spinalgpu
.address_size 32

.visible .entry basic_special_register_store(
    .param .u32 out_ptr_param
)
{
    .reg .u32 %r<11>;

    // Setup
    ld.param.u32 %r0, [out_ptr_param];
    mov.u32 %r1, %tid.x;
    mov.u32 %r2, %laneid;
    mov.u32 %r3, %warpid;
    mov.u32 %r4, %ntid.x;
    mov.u32 %r5, %ctaid.x;
    mov.u32 %r6, %nctaid.x;
    mov.u32 %r7, %nwarpid;
    mov.u32 %r8, %smid;
    mov.u32 %r9, %nsmid;

    // Core
    shl.b32 %r10, %r1, 2;
    add.u32 %r10, %r0, %r10;
    st.global.u32 [%r10 + 0], %r2;
    st.global.u32 [%r10 + 160], %r3;
    st.global.u32 [%r10 + 320], %r4;
    st.global.u32 [%r10 + 480], %r5;
    st.global.u32 [%r10 + 640], %r6;
    st.global.u32 [%r10 + 800], %r7;
    st.global.u32 [%r10 + 960], %r8;
    st.global.u32 [%r10 + 1120], %r9;

    // Exit
    ret;
}
