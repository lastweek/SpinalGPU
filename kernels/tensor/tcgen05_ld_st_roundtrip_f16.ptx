// Purpose: Round-trip one packed FP16 tensor tile through tcgen05 tensor-memory store and load.
// Primary feature: tensor_core
// Expected outcome: success
//
// High-level execution flow:
// - Each lane loads two packed 32-bit words from global memory.
// - The warp stores the 64-word tile into Tensor Memory with `tcgen05.st`, waits for completion,
// - then reloads the same tile with `tcgen05.ld` and writes the words back to global memory.
//
// Where this fits:
// - This is the minimal tcgen05 Tensor Memory teaching kernel.
// - It isolates TMEM load/store behavior before descriptor-driven MMA is introduced.
//
// Key model details:
// - The current repo tcgen05 slice uses one fixed TMEM window per warp and a narrow `%r` tuple syntax.
// - The TMEM address register is warp-uniform and carries a byte address inside the warp's fixed window.
// - The payload tuple is exactly two contiguous `%r` registers, one 32-word beat each.
//
// CUDA-equivalent sketch (.cu):
// __global__ void tcgen05_ld_st_roundtrip_f16(const uint32_t* in_words, uint32_t* out_words) {
//   unsigned lane = threadIdx.x;
//   uint32_t lo = in_words[lane];
//   uint32_t hi = in_words[32 + lane];
//   // tcgen05.st / wait / tcgen05.ld / wait happen here against one warp-local TMEM window.
//   out_words[lane] = lo;
//   out_words[32 + lane] = hi;
// }
//
// SpinalGPU note:
// - This is a deliberately narrow teaching form of tcgen05 that uses contiguous `%r` tuples and one fixed warp-local TMEM window.
.version 8.0
.target spinalgpu
.address_size 32

.visible .entry tcgen05_ld_st_roundtrip_f16(
    .param .u32 in_words_ptr,
    .param .u32 out_words_ptr
)
{
    .reg .u32 %r<10>;

// Setup
    ld.param.u32 %r0, [in_words_ptr];
    ld.param.u32 %r1, [out_words_ptr];
    mov.u32 %r2, %tid.x;
    shl.b32 %r3, %r2, 2;
    add.u32 %r4, %r3, 128;
    mov.u32 %r5, 0;

    add.u32 %r6, %r0, %r3;
    ld.global.u32 %r8, [%r6];
    add.u32 %r7, %r0, %r4;
    ld.global.u32 %r9, [%r7];

// Core
    tcgen05.st.sync.aligned.32x32b.x2.b32 [%r5], {%r8, %r9};
    tcgen05.wait::st.sync.aligned;
    tcgen05.ld.sync.aligned.32x32b.x2.b32 {%r8, %r9}, [%r5];
    tcgen05.wait::ld.sync.aligned;

    add.u32 %r6, %r1, %r3;
    st.global.u32 [%r6], %r8;
    add.u32 %r7, %r1, %r4;
    st.global.u32 [%r7], %r9;

// Exit
    ret;
}
