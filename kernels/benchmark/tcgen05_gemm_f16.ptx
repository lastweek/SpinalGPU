// Purpose: Compare the tcgen05 tensor path against the CUDA-core FP16 GEMM baseline with a one-CTA full-matrix benchmark.
// Primary feature: tensor_core
// Expected outcome: success
// High-level execution flow:
// - One warp owns the whole matrix and walks the `16 x 8` output tiles in raster order.
// - For each output tile, the warp zeroes its TMEM accumulator tile, stages one A tile and one B tile per `k` chunk into shared memory, and issues `tcgen05.mma`.
// - After the `k` loop finishes, the warp reloads the final TMEM tile and stores the row-major `16 x 8` result tile back to global memory.
// Where this fits:
// - This is the tensor-core side of the GEMM benchmark pair.
// - It keeps the benchmark runnable on the single-SM harness while minimizing benchmark-only overhead around the tcgen05 teaching slice.
// Key model details:
// - `blockDim = (32, 1, 1)` gives one full warp, and that warp reuses one shared A staging tile plus one shared B staging tile for the whole kernel.
// - The benchmark support layer only launches aligned shapes where `m % 16 == 0`, `n % 8 == 0`, and `k % 16 == 0`.
// - TMEM base stays fixed at `0`, and control word `0x11` enables FP16 MMA with D reloaded from TMEM on each step.
// CUDA-equivalent sketch (.cu):
// __global__ void tcgen05_gemm_f16(const half* A, const half* B, half* C,
//                                  unsigned m, unsigned n, unsigned k,
//                                  unsigned lda, unsigned ldb, unsigned ldc) {
//   for (unsigned row = 0; row < m; row += 16) {
//     for (unsigned col = 0; col < n; col += 8) {
//       // Zero one TMEM tile, stage A/B for each k-chunk, issue tcgen05.mma, then store one 16x8 output tile.
//     }
//   }
// }
// SpinalGPU note:
// - This uses the repo's narrow tcgen05 teaching slice: fixed warp-local TMEM windows, `%r` descriptor tuples, and commit-after-each-step semantics.

.version 8.0
.target spinalgpu
.address_size 32

.visible .entry tcgen05_gemm_f16(
    .param .u32 A_ptr,
    .param .u32 B_ptr,
    .param .u32 C_ptr,
    .param .u32 m,
    .param .u32 n,
    .param .u32 k,
    .param .u32 lda,
    .param .u32 ldb,
    .param .u32 ldc
)
{
    .reg .u32 %r<29>;
    .pred %p<1>;
    .shared .align 16 .b8 a_tile[512];
    .shared .align 16 .b8 b_tile[256];

// Setup
    ld.param.u32 %r0, [A_ptr];
    ld.param.u32 %r1, [B_ptr];
    ld.param.u32 %r2, [C_ptr];
    ld.param.u32 %r3, [m];
    ld.param.u32 %r4, [n];
    ld.param.u32 %r5, [k];
    ld.param.u32 %r6, [lda];
    ld.param.u32 %r7, [ldb];
    ld.param.u32 %r8, [ldc];
    mov.u32 %r9, %tid.x;
    shl.b32 %r10, %r9, 2;
    mov.u32 %r11, a_tile;
    mov.u32 %r12, 0;
    mov.u32 %r13, b_tile;
    mov.u32 %r14, 0;
    mov.u32 %r15, 17;
    mov.u32 %r16, 0;
    mov.u32 %r17, 0;
    mov.u32 %r18, 0;

// Core
row_loop:
    setp.lt.u32 %p0, %r18, %r3;
    @!%p0 bra done;

    mov.u32 %r19, 0;

col_loop:
    setp.lt.u32 %p0, %r19, %r4;
    @!%p0 bra next_row;

    mov.u32 %r26, 0;
    mov.u32 %r27, 0;
    tcgen05.st.sync.aligned.32x32b.x2.b32 [%r17], {%r26, %r27};
    tcgen05.wait::st.sync.aligned;

    mov.u32 %r20, 0;

tile_k_loop:
    setp.lt.u32 %p0, %r20, %r5;
    @!%p0 bra drain_result;

    mov.u32 %r21, %r9;
    shr.b32 %r21, %r21, 3;
    mov.u32 %r22, %r9;
    and.b32 %r22, %r22, 7;
    shl.b32 %r22, %r22, 1;
    add.u32 %r22, %r22, %r20;

    add.u32 %r23, %r18, %r21;
    mul.lo.u32 %r23, %r23, %r6;
    add.u32 %r23, %r23, %r22;
    shl.b32 %r23, %r23, 1;
    add.u32 %r23, %r0, %r23;
    ld.global.u32 %r24, [%r23];
    add.u32 %r25, %r11, %r10;
    st.shared.u32 [%r25], %r24;

    add.u32 %r23, %r18, %r21;
    add.u32 %r23, %r23, 4;
    mul.lo.u32 %r23, %r23, %r6;
    add.u32 %r23, %r23, %r22;
    shl.b32 %r23, %r23, 1;
    add.u32 %r23, %r0, %r23;
    ld.global.u32 %r24, [%r23];
    add.u32 %r25, %r10, 128;
    add.u32 %r25, %r11, %r25;
    st.shared.u32 [%r25], %r24;

    add.u32 %r23, %r18, %r21;
    add.u32 %r23, %r23, 8;
    mul.lo.u32 %r23, %r23, %r6;
    add.u32 %r23, %r23, %r22;
    shl.b32 %r23, %r23, 1;
    add.u32 %r23, %r0, %r23;
    ld.global.u32 %r24, [%r23];
    add.u32 %r25, %r10, 256;
    add.u32 %r25, %r11, %r25;
    st.shared.u32 [%r25], %r24;

    add.u32 %r23, %r18, %r21;
    add.u32 %r23, %r23, 12;
    mul.lo.u32 %r23, %r23, %r6;
    add.u32 %r23, %r23, %r22;
    shl.b32 %r23, %r23, 1;
    add.u32 %r23, %r0, %r23;
    ld.global.u32 %r24, [%r23];
    add.u32 %r25, %r10, 384;
    add.u32 %r25, %r11, %r25;
    st.shared.u32 [%r25], %r24;

    mov.u32 %r21, %r9;
    shr.b32 %r21, %r21, 2;
    mov.u32 %r22, %r9;
    and.b32 %r22, %r22, 3;
    shl.b32 %r22, %r22, 1;
    add.u32 %r22, %r22, %r19;

    add.u32 %r23, %r20, %r21;
    mul.lo.u32 %r23, %r23, %r7;
    add.u32 %r23, %r23, %r22;
    shl.b32 %r23, %r23, 1;
    add.u32 %r23, %r1, %r23;
    ld.global.u32 %r24, [%r23];
    add.u32 %r25, %r13, %r10;
    st.shared.u32 [%r25], %r24;

    add.u32 %r23, %r20, %r21;
    add.u32 %r23, %r23, 8;
    mul.lo.u32 %r23, %r23, %r7;
    add.u32 %r23, %r23, %r22;
    shl.b32 %r23, %r23, 1;
    add.u32 %r23, %r1, %r23;
    ld.global.u32 %r24, [%r23];
    add.u32 %r25, %r10, 128;
    add.u32 %r25, %r13, %r25;
    st.shared.u32 [%r25], %r24;

    tcgen05.mma.cta_group::1.kind::f16 [%r17], {%r11, %r12}, {%r13, %r14}, {%r15, %r16};
    tcgen05.commit.cta_group::1.sync.aligned;
    add.u32 %r20, %r20, 16;
    bra tile_k_loop;

drain_result:
    tcgen05.ld.sync.aligned.32x32b.x2.b32 {%r26, %r27}, [%r17];
    tcgen05.wait::ld.sync.aligned;

    mov.u32 %r21, %r9;
    shr.b32 %r21, %r21, 2;
    mov.u32 %r22, %r9;
    and.b32 %r22, %r22, 3;
    shl.b32 %r22, %r22, 1;
    add.u32 %r22, %r22, %r19;

    add.u32 %r23, %r18, %r21;
    mul.lo.u32 %r23, %r23, %r8;
    add.u32 %r23, %r23, %r22;
    shl.b32 %r23, %r23, 1;
    add.u32 %r23, %r2, %r23;
    st.global.u32 [%r23], %r26;

    add.u32 %r21, %r21, 8;
    add.u32 %r23, %r18, %r21;
    mul.lo.u32 %r23, %r23, %r8;
    add.u32 %r23, %r23, %r22;
    shl.b32 %r23, %r23, 1;
    add.u32 %r23, %r2, %r23;
    st.global.u32 [%r23], %r27;

    add.u32 %r19, %r19, 8;
    bra col_loop;

next_row:
    add.u32 %r18, %r18, 16;
    bra row_loop;

// Exit
done:
    ret;
}
