flowchart LR
  GRID[GridDispatchController]
  CTA0[CTA desc -> SM 0]
  CTA1[CTA desc -> SM 1]
  READY[SM-local Ready Pool]
  BINDER[WarpBinder]
  SLOT0[SubSm Local Slots]
  EXEC0[CUDA / LSU / SFU / Tensor]
  WB[WarpStateTable + Writeback]

  GRID --> CTA0 --> READY
  GRID --> CTA1
  READY --> BINDER --> SLOT0 --> EXEC0 --> WB
